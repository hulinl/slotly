# Copy to .env (or backend/.env) and fill in real values for your local environment.
# Never commit .env files.

# --- Django ---
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (matches docker-compose.yml) ---
# Host port 25432 (not the default 5432) so this can coexist with other dev
# Postgres instances on the same machine.
DATABASE_URL=postgres://slotly:slotly_dev_password@localhost:25432/slotly

# --- Redis (Celery broker + cache, matches docker-compose.yml) ---
# Host port 26379 (not the default 6379), same coexistence reason as above.
REDIS_URL=redis://localhost:26379/0
CELERY_BROKER_URL=redis://localhost:26379/1
CELERY_RESULT_BACKEND=redis://localhost:26379/2

# --- Email (MailHog locally; Azure Communication Services in prod) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=no-reply@slotly.local

# --- Frontend → Backend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Calendar URL encryption ---
# 32-byte base64 key used to envelope-encrypt subscribed ICS URLs at the application layer.
# Generate locally: python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
# In production this is fetched from Azure Key Vault.
CALENDAR_URL_ENCRYPTION_KEY=

# --- Google Calendar OAuth (M18a) ---
# Web-application OAuth 2.0 client from Google Cloud Console:
#   APIs & Services → Credentials → Create OAuth 2.0 Client ID → Web application.
# Authorized redirect URIs in GCC must include both:
#   http://localhost:8000/api/oauth/google/callback     (dev)
#   https://api.slotly.team/api/oauth/google/callback    (prod)
# Leave empty until the Connect Google flow is wired; endpoints return 503
# with a clear message when unconfigured.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback

# --- Sentry (optional, leave blank locally) ---
SENTRY_DSN=
